{
  "name": "finance-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Локальное десктоп-приложение для учета финансов",
  "main": "dist-electron/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsup src/main/index.ts src/main/preload.ts --format cjs --platform node --external electron --external better-sqlite3 --out-dir dist-electron --sourcemap --watch",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electronmon dist-electron/index.js",
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"wait-on tcp:5173 file:dist-electron/index.js && npm:dev:electron\"",
    "build:renderer": "vite build",
    "build:main": "rimraf dist-electron && tsup src/main/index.ts src/main/preload.ts --format cjs --platform node --external electron --external better-sqlite3 --out-dir dist-electron --minify",
    "build": "npm run build:renderer && npm run build:main",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.59.0",
    "better-sqlite3": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
